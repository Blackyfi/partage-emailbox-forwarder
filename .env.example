# Partage / CAS credentials
PARTAGE_USERNAME=prenom.nom@bordeaux-inp.fr
PARTAGE_PASSWORD=your_password_here
PARTAGE_URL=https://partage.bordeaux-inp.fr/mail
CAS_URL=https://cas.bordeaux-inp.fr/login?service=https://partage.bordeaux-inp.fr

# Gmail SMTP (use App Password, not account password)
FORWARD_TO=your.email@gmail.com
GMAIL_USER=your.sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Tuning (optional)
POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
DB_PATH=/data/emails.db
BROWSER_TIMEOUT_MS=20000
